# ==============================================================================
# GoPieMenu Git Ignore Rules
# ==============================================================================

# === OS Files ===
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# === C++ / Compilers ===
*.o
*.obj
*.exe
*.dll
*.so
*.dylib
*.pdb
*.ilk
*.exp
*.lib
*.gch
*.pch

# === Qt 6 / CMake (Build Artifacts) ===
build*/
out/
bin/
x64/
ARM64/

# === CMake ===
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/

# === Qt (Moc, UI, Resource) ===
mocs_compilation*
*.moc
moc_*.cpp
moc_*.h
ui_*.h
qrc_*.cpp
*.qrc.depends
*_qmlcache.qrc
*_qmltyperegistrar.cpp
*_qmlresourcetypeloader.cpp

*.qm

# === IDEs (Rider, VS, QtCreator) ===
# JetBrains Rider / CLion
.idea/
*.sln.iml
.solution.autofit

# === Visual Studio ===
.vs/
*.user
*.suo
*.db
*.opendb

# === Qt Creator ===
*.pro.user
*.pro.user.*
*.qbs.user
*.qbs.user.*
CMakeLists.txt.user*

# === Backup & Temp Files ===
*.bak
*.swp
*~
*.autosave

# ==============================================================================
# Safety Rules
# ==============================================================================

!CMakeLists.txt
!LICENSE
!README.md